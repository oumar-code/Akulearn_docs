# Vercel deploys the Next.js dashboard from the akulearn-dashboard/ directory.
# Directory exclusions use a leading / to match only root-level directories,
# preventing them from accidentally matching sub-directories inside akulearn-dashboard/.

# Documentation build artefacts (no longer built by Vercel)
/docs/
/mkdocs.yml
/requirements.txt

# Source code and application directories (not part of the Next.js dashboard)
/akulearn_microservices/
/akulearn-linux-app/
/client_examples/
/connected_stack/
/content/
/content_templates/
/data/
/diagrams/
/examples/
/hardware/
/hardware_integration/
/infra/
/infrastructure/
/knowledge_graph/
/kubernetes/
/marketing/
/mlops/
/personal_portfolio/
/public/
/scripts/
/src/
/static/
/tests/
/unconnected_stack/
/versatech_profile/
/web/
/KOTLIN MULTIPLATFORM/

# Python scripts (content generation, testing, utilities)
*.py

# Shell and batch scripts
*.sh
*.bat
*.ps1

# Data and notebook files
*.ipynb
*.csv

# Exclude root-level JSON data/content files but keep vercel.json
/puppeteer-config.json
/package.json
/package-lock.json

# Go source files
*.go
/go.mod

# Root-level IDE and config files
/.vscode/
/.idea/

# Allow everything inside akulearn-dashboard/ (the Next.js app)
!akulearn-dashboard/
!akulearn-dashboard/**
