# Vercel now serves the Akudemy static site from the public/ directory.
# Everything except public/ is excluded to keep the deployment fast and clean.

# Documentation build artefacts (no longer built by Vercel)
docs/
mkdocs.yml
requirements.txt

# Source code and application directories
akulearn_microservices/
akulearn-linux-app/
client_examples/
connected_stack/
content/
content_templates/
data/
diagrams/
examples/
hardware/
hardware_integration/
infra/
infrastructure/
knowledge_graph/
kubernetes/
marketing/
mlops/
personal_portfolio/
scripts/
src/
static/
tests/
unconnected_stack/
versatech_profile/
web/
KOTLIN MULTIPLATFORM/

# Python scripts (content generation, testing, utilities)
*.py

# Shell and batch scripts
*.sh
*.bat
*.ps1

# Data and notebook files
*.ipynb
*.csv
# Exclude large JSON data/content files but keep vercel.json and package.json
*.json
!vercel.json
!package.json

# Go source files
*.go
go.mod

# Root-level HTML/CSS files (not part of the static site)
*.html
*.css

# Allow everything inside public/ (the Akudemy static site)
!public/
!public/**
