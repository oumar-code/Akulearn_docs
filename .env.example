# API Keys for Asset Generation
# ==============================

# Google Gemini Nano API Key (for diagram generation: PlantUML, Graphviz, ASCII)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Banana API Key (for illustration generation via Stable Diffusion)
# Get from: https://www.banana.dev/
BANANA_API_KEY=your_banana_api_key_here

# Optional: Banana Model ID (defaults to stable-diffusion-v1-5)
# BANANA_MODEL_ID=stable-diffusion-v1-5

# Translation (Masakhane/HF) and Tone Validation (NaijaSenti)
# Set a translation model, e.g., Helsinki-NLP/opus-mt-en-ha or a Masakhane MT model
HUGGINGFACE_TRANSLATION_MODEL=
# Set a sentiment model, e.g., Davlan/afro-xlmr-mini-finetuned-sentiment
NAIJASENTI_MODEL=
# If using private models, set your HF token
HUGGINGFACE_TOKEN=

# Supabase (used by supabase_provision.py for team onboarding)
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend (used by Akuplatform for transactional email)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
