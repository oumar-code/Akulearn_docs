# =============================================================================
# Aku Platform — Master Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in real values before running locally.
# NEVER commit a populated .env to version control.
#
# For K8s deployments use docs/deployment/k8s/secrets.yaml (placeholder
# templates) and inject real values via kubectl or a secrets manager.
# For the local Docker Compose dev stack see docs/deployment/local/docker-compose.dev.yml.
# =============================================================================


# ── Shared Infrastructure ─────────────────────────────────────────────────────
# Single shared PostgreSQL instance for local dev.
# Each service connects with its own user and schema (or the same user in dev).
# Get from: your hosted Postgres provider, or use the Docker Compose infra profile.

POSTGRES_USER=aku
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=aku_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# Shared Redis instance; each service uses a separate DB index.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Neo4j (knowledge graph) ───────────────────────────────────────────────────
NEO4J_AUTH=neo4j/change_me_in_production


# =============================================================================
# AkuAI — Shared Inference Layer  (port 8004)
# =============================================================================
AKUAI_APP_ENV=development
AKUAI_LOG_LEVEL=info
# Service-to-service API secret (required by all callers of AkuAI)
AKUAI_API_SECRET=change_me_in_production
# PostgreSQL connection for inference logs / audit trail
AKUAI_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform
# Redis DB 2 — response cache & rate limiting
AKUAI_REDIS_URL=redis://localhost:6379/2
# Local model weights (leave empty in dev to use stub responses)
AKUAI_MODEL_DIR=
AKUAI_GEMMA_GGUF_PATH=
AKUAI_GEMMA_MAX_PAYLOAD_BYTES=4096
AKUAI_CORS_ORIGINS=http://localhost:3000
# Optional: HuggingFace token for downloading gated/private models (e.g. Gemma)
AKUAI_HUGGINGFACE_TOKEN=
AKUAI_HF_HOME=/mnt/models/hf_cache
# Optional: hosted LLM provider keys (only needed if routing inference to the cloud)
AKUAI_OPENAI_API_KEY=
AKUAI_ANTHROPIC_API_KEY=
AKUAI_GOOGLE_API_KEY=


# =============================================================================
# Akudemy — Content Delivery & Credential Issuance  (port 8000)
# =============================================================================
AKUDEMY_APP_ENV=development
AKUDEMY_LOG_LEVEL=info
AKUDEMY_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform
# Redis DB 3 — content-sync cache
AKUDEMY_REDIS_URL=redis://localhost:6379/3
AKUDEMY_REDIS_SYNC_TTL_SECONDS=30
AKUDEMY_CORS_ALLOWED_ORIGINS=http://localhost:3000
# Secret shared with Edge Hubs for /content/sync authentication
AKUDEMY_EDGE_HUB_SHARED_SECRET=change_me_in_production
# Aku-Content library — base URL for seeding content from the GitHub content repo
AKUDEMY_AKU_CONTENT_BASE_URL=https://raw.githubusercontent.com/oumar-code/Aku-Content/main

# Polygon / Web3 — blockchain credential issuance
# RPC endpoint — use Alchemy / Infura / QuickNode in production
AKUDEMY_POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
AKUDEMY_POLYGON_NETWORK=amoy                    # amoy (testnet) | polygon (mainnet)
# Issuer wallet — store the private key in a secrets manager in production; never hardcode
AKUDEMY_POLYGON_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
AKUDEMY_POLYGON_ISSUER_ADDRESS=0xYOUR_ISSUER_ADDRESS_HERE
# On-chain credential contract (ERC-721 or ERC-1155)
AKUDEMY_CREDENTIAL_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Supabase (optional — only if Akudemy uses Supabase for auth / storage)
AKUDEMY_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
AKUDEMY_SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY


# =============================================================================
# Aku-EdgeHub — Offline-First Edge Server  (port 8000)
# =============================================================================
EDGEHUB_APP_ENV=development
EDGEHUB_LOG_LEVEL=info
# "online" → syncs to cloud; "offline" → fully local, no outbound calls
EDGEHUB_OPERATING_MODE=online
# SQLite for local dev; swap for postgresql+asyncpg in staging/production
EDGEHUB_DATABASE_URL=sqlite+aiosqlite:///./edge_hub.db
# Redis DB 4
EDGEHUB_REDIS_URL=redis://localhost:6379/4
# Service-to-service keys for calling Akudemy and AkuAI
EDGEHUB_AKUDEMY_BASE_URL=http://localhost:8000
EDGEHUB_AKUDEMY_API_KEY=change_me_in_production
EDGEHUB_AKUAI_BASE_URL=http://localhost:8004
EDGEHUB_AKUAI_API_KEY=change_me_in_production


# =============================================================================
# Aku-IGHub — Global API Gateway  (port 8000)
# =============================================================================
IGHUB_APP_ENV=development
IGHUB_LOG_LEVEL=info
# Redis DB 5 — idempotency store
IGHUB_REDIS_URL=redis://localhost:6379/5
IGHUB_IDEMPOTENCY_TTL_SECONDS=86400
IGHUB_ALLOWED_ORIGINS=http://localhost:3000
# JWT — use RS256 (asymmetric) in production; HS256 only for local dev
IGHUB_JWT_ALGORITHM=RS256
IGHUB_JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
# HS256 dev-only fallback (comment out in production)
IGHUB_JWT_SECRET_KEY=CHANGE_ME_dev_only
# IGHub's W3C DID (used as VC issuer in the credential registry)
IGHUB_SERVICE_DID=did:web:ighub.akulearn.io
# DaaS metadata ingest endpoint
IGHUB_DAAS_INGEST_URL=http://localhost:8001/api/v1/ingest/metadata
# VC / DID resolver
IGHUB_DID_RESOLVER_URL=https://resolver.identity.foundation
IGHUB_VC_REVOCATION_REGISTRY_URL=https://registry.akulearn.io/revocation
IGHUB_RATE_LIMIT_PER_MINUTE=120
# PostgreSQL (referenced as a secret in K8s; used for credential registry persistence)
IGHUB_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform


# =============================================================================
# Aku-SuperHub — Regional Analytics Gateway  (port 8000)
# =============================================================================
SUPERHUB_APP_ENV=development
SUPERHUB_LOG_LEVEL=INFO
SUPERHUB_REGION_CODE=us-east-1
SUPERHUB_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform
SUPERHUB_DATABASE_POOL_SIZE=10
SUPERHUB_DATABASE_MAX_OVERFLOW=20
# Redis DB 6
SUPERHUB_REDIS_URL=redis://localhost:6379/6
SUPERHUB_REDIS_POOL_SIZE=10
# JWT — symmetric HS256 acceptable for SuperHub internal auth in staging
SUPERHUB_JWT_SECRET_KEY=change_me_in_production
SUPERHUB_JWT_ALGORITHM=HS256
SUPERHUB_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Inter-service API keys
SUPERHUB_AKU_AI_URL=http://localhost:8004
SUPERHUB_AKU_IGHUB_URL=http://localhost:8008
SUPERHUB_AKU_PLATFORM_API_KEY=change_me_in_production
# ML pipeline orchestrator (Ray / Kubeflow / custom)
SUPERHUB_ML_PIPELINE_URL=https://ml-pipeline.akulearn.internal
SUPERHUB_ML_PIPELINE_API_KEY=change_me_in_production
SUPERHUB_MAX_CONCURRENT_FINETUNE_JOBS=2
# Observability
SUPERHUB_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
SUPERHUB_PROMETHEUS_METRICS_PORT=9090


# =============================================================================
# AkuTutor — AI Tutoring Service  (port 8002)
# =============================================================================
AKUTUTOR_APP_ENV=development
AKUTUTOR_LOG_LEVEL=INFO
AKUTUTOR_AKU_AI_URL=http://localhost:8004
# Database and Redis (for session persistence)
AKUTUTOR_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform
AKUTUTOR_REDIS_URL=redis://localhost:6379/9


# =============================================================================
# AkuWorkspace — AI-Native Productivity Suite  (port 8004)
# =============================================================================
AKUWORKSPACE_APP_ENV=development
AKUWORKSPACE_LOG_LEVEL=info
AKUWORKSPACE_AKU_AI_URL=http://localhost:8004
AKUWORKSPACE_AKUDEMY_URL=http://localhost:8000
AKUWORKSPACE_AKU_DAAS_URL=http://localhost:8001
# Redis DB 7 — per-user context storage
AKUWORKSPACE_REDIS_URL=redis://localhost:6379/7
AKUWORKSPACE_HTTP_TIMEOUT=30.0
AKUWORKSPACE_CORS_ORIGINS=http://localhost:3000
AKUWORKSPACE_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform


# =============================================================================
# Aku-Telhone — eSIM Provisioning  (port 8001)
# =============================================================================
TELHONE_APP_ENV=development
TELHONE_LOG_LEVEL=info
TELHONE_ALLOWED_ORIGINS=http://localhost:3000
# SM-DP+ / OTA provisioning
TELHONE_SMDP_BASE_URL=https://smdp.telhone.akulearn.io
TELHONE_SMDP_API_KEY=CHANGE_ME
TELHONE_MVNO_OPERATOR_ID=akulearn-mvno
TELHONE_QR_BASE_URL=https://qr.telhone.akulearn.io
TELHONE_OTA_PLATFORM_URL=https://ota.telhone.akulearn.io
TELHONE_OTA_PLATFORM_API_KEY=CHANGE_ME
TELHONE_OTA_TIMEOUT_SECONDS=30
# Aku-IGHub integration (device attestation)
TELHONE_AKU_IGHUB_URL=http://localhost:8008
TELHONE_AKU_IGHUB_API_KEY=CHANGE_ME
TELHONE_IGHUB_TIMEOUT_SECONDS=10
# JWT bearer token verification
TELHONE_JWT_ALGORITHM=RS256
TELHONE_JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem
# HS256 dev-only fallback (comment out in production)
TELHONE_JWT_SECRET_KEY=CHANGE_ME_dev_only
TELHONE_RATE_LIMIT_PER_MINUTE=60
TELHONE_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform
TELHONE_REDIS_URL=redis://localhost:6379/10


# =============================================================================
# Aku-DaaS — Data Governance & Anonymisation  (port 8001)
# =============================================================================
DAAS_APP_ENV=development
DAAS_LOG_LEVEL=info
DAAS_DATABASE_URL=postgresql+asyncpg://aku:change_me_in_production@localhost:5432/aku_platform
# Redis DB 8 — pipeline status pub/sub & distributed lock
DAAS_REDIS_URL=redis://localhost:6379/8
DAAS_PIPELINE_STATUS_TTL_SECONDS=604800
DAAS_ALLOWED_ORIGINS=http://localhost:3000
# IGHub metadata publish integration
DAAS_IGHUB_METADATA_PUBLISH_URL=http://localhost:8008/api/v1/metadata/publish
DAAS_IGHUB_SERVICE_TOKEN=CHANGE_ME_service_token
# Object storage (AWS S3 or MinIO)
DAAS_OBJECT_STORAGE_BUCKET=daas-datasets
DAAS_OBJECT_STORAGE_RAW_PREFIX=raw/
DAAS_OBJECT_STORAGE_ANONYMISED_PREFIX=anonymised/
DAAS_AWS_ACCESS_KEY_ID=CHANGE_ME
DAAS_AWS_SECRET_ACCESS_KEY=CHANGE_ME
# MinIO local override — leave empty to use AWS S3
DAAS_AWS_ENDPOINT_URL=
# Anonymisation defaults
DAAS_DEFAULT_K_VALUE=5
DAAS_DEFAULT_SUPPRESS_THRESHOLD=0.05
DAAS_RATE_LIMIT_PER_MINUTE=60


# =============================================================================
# Supabase (team provisioning + Next.js dashboard)
# =============================================================================
# Used by supabase_provision.py for team onboarding.
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Next.js dashboard (akulearn-dashboard/)
# Next.js only exposes NEXT_PUBLIC_* variables to the browser.
# Get the anon key from: Supabase Dashboard > Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# =============================================================================
# Resend — Transactional Email
# =============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
# "From" address — must be a verified Resend sender domain
RESEND_FROM_EMAIL=onboarding@akulearn.com


# =============================================================================
# AI / ML Pipeline Tools (used by pipeline/ scripts and asset generation)
# =============================================================================

# Google Gemini API (diagram generation: PlantUML, Graphviz, ASCII)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Banana / Stable Diffusion (illustration generation)
# Get from: https://www.banana.dev/
BANANA_API_KEY=your_banana_api_key_here
# BANANA_MODEL_ID=stable-diffusion-v1-5

# HuggingFace — translation (Masakhane) and sentiment (NaijaSenti) models
# e.g., Helsinki-NLP/opus-mt-en-ha or a Masakhane MT model
HUGGINGFACE_TRANSLATION_MODEL=
# e.g., Davlan/afro-xlmr-mini-finetuned-sentiment
NAIJASENTI_MODEL=
# Required for private / gated models
HUGGINGFACE_TOKEN=


# =============================================================================
# Mapbox (interactive network map — docs/network-map/index.html)
# =============================================================================
# Public access token starting with pk.
# Scope the token to your deployed domain in the Mapbox dashboard.
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=MAPBOX_TOKEN_PLACEHOLDER


# =============================================================================
# Vercel (CI/CD deployment — .github/workflows/vercel-deploy.yml)
# =============================================================================
VERCEL_TOKEN=your_vercel_personal_access_token
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id
