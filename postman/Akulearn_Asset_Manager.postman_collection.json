{
  "info": {
    "name": "Akulearn Asset Manager API",
    "_postman_id": "akulearn-asset-manager-v1",
    "description": "Smoke-test collection for the three core Asset Manager endpoints.\n\nImport this file together with `Akulearn_Asset_Manager.postman_environment.json` so that `{{base_url}}` and the API-key variables resolve correctly.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 – Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/assets/health",
          "host": ["{{base_url}}"],
          "path": ["api", "assets", "health"]
        },
        "description": "Verifies the server is up and reports which third-party API keys are configured."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Body has status field', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('status');",
              "});",
              "",
              "pm.test('Body has apis field', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('apis');",
              "});",
              "",
              "pm.test('Response time < 2000 ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ]
          }
        }
      ],
      "response": [
        {
          "name": "Healthy – no API keys configured",
          "status": "OK",
          "code": 200,
          "header": [{"key": "Content-Type", "value": "application/json"}],
          "body": "{\n  \"status\": \"healthy\",\n  \"apis\": {\n    \"unsplash\": false,\n    \"pexels\": false,\n    \"replicate\": false,\n    \"openai\": false\n  }\n}"
        }
      ]
    },
    {
      "name": "2 – Search Images (all sources)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/assets/search?query={{search_query}}&source={{search_source}}&per_page={{per_page}}",
          "host": ["{{base_url}}"],
          "path": ["api", "assets", "search"],
          "query": [
            {"key": "query",    "value": "{{search_query}}"},
            {"key": "source",   "value": "{{search_source}}"},
            {"key": "per_page", "value": "{{per_page}}"}
          ]
        },
        "description": "Search stock-image sources (unsplash, pexels, or all). Requires the corresponding API key(s) to be set in the environment."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "});",
              "",
              "pm.test('Each result has id and url', function () {",
              "    const json = pm.response.json();",
              "    if (json.length > 0) {",
              "        pm.expect(json[0]).to.have.property('id');",
              "        pm.expect(json[0]).to.have.property('url');",
              "    }",
              "});",
              "",
              "pm.test('Response time < 5000 ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ]
          }
        }
      ],
      "response": [
        {
          "name": "Images found",
          "status": "OK",
          "code": 200,
          "header": [{"key": "Content-Type", "value": "application/json"}],
          "body": "[\n  {\n    \"id\": \"abc123\",\n    \"url\": \"https://images.unsplash.com/photo-xyz\",\n    \"thumbnail_url\": \"https://images.unsplash.com/photo-xyz?w=200\",\n    \"description\": \"Green plant photosynthesis process\",\n    \"source\": \"unsplash\",\n    \"photographer\": \"John Doe\",\n    \"photographer_url\": \"https://unsplash.com/@johndoe\"\n  }\n]"
        }
      ]
    },
    {
      "name": "3 – Generate AI Asset",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"{{generate_prompt}}\",\n  \"type\": \"{{generate_type}}\",\n  \"subject\": \"{{generate_subject}}\",\n  \"style\": \"{{generate_style}}\"\n}",
          "options": {"raw": {"language": "json"}}
        },
        "url": {
          "raw": "{{base_url}}/api/assets/generate",
          "host": ["{{base_url}}"],
          "path": ["api", "assets", "generate"]
        },
        "description": "Kick off AI-powered asset generation (image). Requires a Replicate or OpenAI key."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 or 202', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
              "});",
              "",
              "pm.test('Body has asset_id', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('asset_id');",
              "});",
              "",
              "pm.test('Body has status field', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('status');",
              "});",
              "",
              "pm.test('Response time < 10000 ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
      ],
      "response": [
        {
          "name": "Generation queued",
          "status": "OK",
          "code": 200,
          "header": [{"key": "Content-Type", "value": "application/json"}],
          "body": "{\n  \"asset_id\": \"gen_Education\",\n  \"asset_url\": \"https://placeholder.com/generated.png\",\n  \"status\": \"processing\",\n  \"message\": \"Asset generation started. Check back in a few minutes.\"\n}"
        }
      ]
    }
  ],
  "variable": []
}
