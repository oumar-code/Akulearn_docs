{
  "id": "akulearn-asset-manager-env-v1",
  "name": "Akulearn Asset Manager - Local",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "default",
      "enabled": true,
      "description": "Root URL of the FastAPI server. Change to your deployed URL when testing in staging/production."
    },
    {
      "key": "unsplash_key",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Unsplash Access Key (UNSPLASH_ACCESS_KEY). Required for source=unsplash searches."
    },
    {
      "key": "pexels_key",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Pexels API Key (PEXELS_API_KEY). Required for source=pexels searches."
    },
    {
      "key": "replicate_key",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Replicate API token. Required for AI image generation."
    },
    {
      "key": "openai_key",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "OpenAI API key. Required if using the OpenAI-backed generation path."
    },
    {
      "key": "search_query",
      "value": "photosynthesis",
      "type": "default",
      "enabled": true,
      "description": "Default search term used in the Search Images request."
    },
    {
      "key": "search_source",
      "value": "all",
      "type": "default",
      "enabled": true,
      "description": "Image source: unsplash | pexels | all"
    },
    {
      "key": "per_page",
      "value": "10",
      "type": "default",
      "enabled": true,
      "description": "Number of results per page for search requests."
    },
    {
      "key": "generate_prompt",
      "value": "Educational diagram of photosynthesis",
      "type": "default",
      "enabled": true,
      "description": "Prompt sent to the AI generation endpoint."
    },
    {
      "key": "generate_type",
      "value": "image",
      "type": "default",
      "enabled": true,
      "description": "Asset type to generate (e.g. image)."
    },
    {
      "key": "generate_subject",
      "value": "Biology",
      "type": "default",
      "enabled": true,
      "description": "Subject area for the generated asset."
    },
    {
      "key": "generate_style",
      "value": "educational",
      "type": "default",
      "enabled": true,
      "description": "Visual style for the generated asset."
    }
  ],
  "_postman_variable_scope": "environment",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/environment.json"
}
