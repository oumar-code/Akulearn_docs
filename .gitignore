# Ignore environment variable files
.env
node_modules
package-lock.json

# MkDocs build output
site/

# Python
__pycache__/
*.py
!team.py
!supabase_provision.py
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
myenv/

# Shell and batch scripts
*.sh
*.bat
*.ps1

# Exceptions: Gradle wrapper scripts and build scripts (required for Android Studio / KMP)
!gradlew
!gradlew.bat
!build-all.sh
!setup.sh

# Go source
*.go
go.mod
go.sum

# Docker / container
Dockerfile
compose*.yaml
compose*.yml
docker-compose*.yaml
docker-compose*.yml

# Logs and temporary outputs
*.log
*.out
*.err
*.txt
!requirements.txt

# Editor/IDE
.idea/

# Misc
*.zip
*.egg-info/

# Database files
*.db
*.sqlite
*.sqlite3

# Generated and output directories
generated_assets/
generated_images/
generated_content/
image_queue/
graph_exports/
runs/
reports/

# Gradle build cache and local config (Android/KMP)
.gradle/
local.properties

# Non-docs directories
akulearn-linux-app/
akulearn_microservices/
client_examples/
connected_stack/
content/
!akulearn-dashboard/app/content/
!akulearn-dashboard/app/content/**
content_templates/
data/
!docs/network-map/data/
diagrams/
examples/
hardware/
!docs/hardware/
hardware_integration/
infra/
infrastructure/
knowledge_graph/
kubernetes/
marketing/
mlops/
personal_portfolio/
scripts/
/src/
static/
tests/
unconnected_stack/
versatech_profile/
web/

# Root-level HTML/CSS dashboards
*.html
*.css

# Allow Next.js dashboard CSS and static files
!akulearn-dashboard/**/*.css
!akulearn-dashboard/**/*.tsx
!akulearn-dashboard/**/*.ts

# Allow the Akudemy static site in public/
!public/
!public/**

# JSON data files (keep vercel.json and package.json and puppeteer-config.json)
*.json
!vercel.json
!package.json
!puppeteer-config.json
!public/*.json

# Allow Next.js dashboard config files
!akulearn-dashboard/*.json
!akulearn-dashboard/**/*.json

# CSV data files
*.csv

# Environment / secrets
.env
