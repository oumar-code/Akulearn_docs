# AkuWorkspace — environment variables
# Copy to .env and fill in real values before running the service.
# Never commit a populated .env file to version control.

# ── Downstream micro-service base URLs ─────────────────────────────────────
AKU_AI_URL=http://akuai:8001
AKU_DAAS_URL=http://aku-daas:8002
AKUDEMY_URL=http://akudemy:8003

# ── Redis (per-user context storage) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Service identity ────────────────────────────────────────────────────────
SERVICE_NAME=akuworkspace
SERVICE_VERSION=0.1.0
LOG_LEVEL=info

# ── HTTP client tuning ──────────────────────────────────────────────────────
HTTP_TIMEOUT=30.0

# ── CORS (comma-separated allowed origins) ─────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://app.akulearn.com
