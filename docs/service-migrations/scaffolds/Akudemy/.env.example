# ─────────────────────────────────────────────────────────────────────────────
# Akudemy — environment variables
# Copy to .env and fill in real values. Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── FastAPI / Uvicorn ─────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info                         # debug | info | warning | error

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://akudemy:password@localhost:5432/akudemy

# ── Redis (content-sync cache) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SYNC_TTL_SECONDS=30

# ── Polygon / Web3 ────────────────────────────────────────────────────────────
# RPC endpoint — use Alchemy / Infura / QuickNode in production
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_NETWORK=amoy                   # amoy (testnet) | polygon (mainnet)

# Issuer wallet — never expose the real private key in plaintext in production;
# use a secrets manager (e.g. AWS Secrets Manager, Vault, GCP Secret Manager).
POLYGON_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYGON_ISSUER_ADDRESS=0xYOUR_ISSUER_ADDRESS_HERE

# On-chain credential contract (ERC-721 or ERC-1155)
CREDENTIAL_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# ── Supabase (if used for auth / storage) ─────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dashboard.akulearn.example

# ── Edge Hub shared secret (for /content/sync auth) ──────────────────────────
EDGE_HUB_SHARED_SECRET=change-me-in-production

# ── Aku-Content (content library source repo) ─────────────────────────────────
# Base URL for the Aku-Content GitHub repo raw files.
# Used when seeding/refreshing the content database from the content library.
# Repo: https://github.com/oumar-code/Aku-Content
AKU_CONTENT_BASE_URL=https://raw.githubusercontent.com/oumar-code/Aku-Content/main
# Optional: submodule path if Aku-Content is cloned locally as a submodule
# AKU_CONTENT_LOCAL_PATH=/opt/aku-content
