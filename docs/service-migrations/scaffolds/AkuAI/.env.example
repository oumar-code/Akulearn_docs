# AkuAI — Environment variable template
# Copy to .env and fill in real values before running locally or in CI.

# ── Service ───────────────────────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_PORT=8004
LOG_LEVEL=info                             # debug | info | warning | error

# ── Authentication ────────────────────────────────────────────────────────────
# Internal service-to-service JWT secret shared across the Aku Platform.
AKUAI_API_SECRET=change_me_in_production

# ── Model paths (local) ───────────────────────────────────────────────────────
# Absolute path to the directory where GGUF / HuggingFace model weights are stored.
MODEL_DIR=/mnt/models/akuai

# Gemma GGUF weight file (used by llama-cpp-python for Edge Hub relay)
GEMMA_GGUF_PATH=/mnt/models/akuai/gemma-2b-it-q4_k_m.gguf

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Optional — set to download private / gated models (e.g. Gemma from HF Hub).
HUGGINGFACE_TOKEN=

# Cache directory for downloaded weights (defaults to ~/.cache/huggingface)
HF_HOME=/mnt/models/hf_cache

# ── External provider API keys (optional) ────────────────────────────────────
# Only required if routing inference to hosted providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Database / persistence ────────────────────────────────────────────────────
# Used to persist inference request logs and audit trail.
DATABASE_URL=postgresql+asyncpg://akuai:akuai_pass@localhost:5432/akuai

# ── Redis (response cache & rate limiting) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/2

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Use * only in development.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Edge Hub settings ─────────────────────────────────────────────────────────
# Maximum allowed payload size for the /models/gemma/infer endpoint (bytes).
GEMMA_MAX_PAYLOAD_BYTES=4096
