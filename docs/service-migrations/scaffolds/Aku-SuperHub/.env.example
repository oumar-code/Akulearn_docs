# ============================================================
# Aku-SuperHub — environment configuration template
# Copy to .env and fill in real values before starting the service.
# NEVER commit .env to version control.
# ============================================================

# ------ Service identity ----------------------------------------
SERVICE_NAME=aku-superhub
SERVICE_ENV=development          # development | staging | production
REGION_CODE=us-east-1            # Logical region this SuperHub manages
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ------ Server --------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4                        # Uvicorn worker count (prod: match CPU cores)

# ------ PostgreSQL (analytics store) ----------------------------
DATABASE_URL=postgresql+asyncpg://superhub:changeme@localhost:5432/superhub_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ------ Redis (cache / pub-sub) ---------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# ------ Authentication ------------------------------------------
JWT_SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------ Inter-service communication -----------------------------
# URL of the central Aku-Platform API (used for model registry lookups)
AKU_PLATFORM_API_URL=https://platform.akulearn.internal/api/v1
AKU_PLATFORM_API_KEY=replace-with-service-api-key

# ------ ML / Fine-tuning pipeline --------------------------------
# Endpoint of the training orchestrator (e.g., Ray, Kubeflow, custom)
ML_PIPELINE_URL=https://ml-pipeline.akulearn.internal
ML_PIPELINE_API_KEY=replace-with-ml-pipeline-api-key
# Maximum concurrent fine-tune jobs allowed per SuperHub
MAX_CONCURRENT_FINETUNE_JOBS=2

# ------ Observability -------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_METRICS_PORT=9090

# ------ Pagination defaults -------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ------ Analytics ingest ----------------------------------------
# Maximum batch size accepted by POST /api/v1/analytics/aggregate
MAX_ANALYTICS_BATCH_SIZE=1000
