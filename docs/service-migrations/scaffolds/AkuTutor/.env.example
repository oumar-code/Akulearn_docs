# ──────────────────────────────────────────────
# AkuTutor environment configuration
# Copy to .env and fill in real values.
# ──────────────────────────────────────────────

# URL of the AkuAI service (text generation backend)
# AkuTutor never runs its own model — it delegates all inference here.
AKU_AI_URL=http://akuai:8001

# Human-readable name shown in OpenAPI docs
APP_NAME=AkuTutor

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
