# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                              # development | staging | production
LOG_LEVEL=info

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# DaaS sits behind IGHub in production — JWT auth is enforced at the gateway.
# Enable these if deploying DaaS with a standalone auth boundary:
# JWT_ALGORITHM=RS256
# JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=Aku-DaaS
SERVICE_VERSION=0.1.0

# ── Aku-IGHub integration ─────────────────────────────────────────────────────
IGHUB_METADATA_PUBLISH_URL=https://ighub.akulearn.io/api/v1/metadata/publish
# Internal service-to-service token (scoped to metadata:publish)
IGHUB_SERVICE_TOKEN=CHANGE_ME_service_token

# ── Database (persistent dataset + consent store) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://daas:CHANGE_ME@localhost:5432/daas
# For local development without PostgreSQL, swap for SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./daas_dev.db

# ── Object storage (raw + anonymised datasets) ────────────────────────────────
OBJECT_STORAGE_BUCKET=daas-datasets
OBJECT_STORAGE_RAW_PREFIX=raw/
OBJECT_STORAGE_ANONYMISED_PREFIX=anonymised/
# AWS / MinIO credentials:
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_ENDPOINT_URL=http://localhost:9000          # MinIO local override

# ── Redis (pipeline status pub/sub + distributed lock) ───────────────────────
REDIS_URL=redis://localhost:6379/1
PIPELINE_STATUS_TTL_SECONDS=604800              # 7-day retention for status keys

# ── Anonymisation defaults ────────────────────────────────────────────────────
DEFAULT_K_VALUE=5                               # k-anonymity minimum equivalence class size
DEFAULT_SUPPRESS_THRESHOLD=0.05                 # max 5 % row suppression before abort

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.akulearn.io,https://admin.akulearn.io

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
