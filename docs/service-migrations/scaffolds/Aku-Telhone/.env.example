# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
LOG_LEVEL=info

# ── JWT / Auth ────────────────────────────────────────────────────────────────
JWT_ALGORITHM=RS256                          # RS256 recommended; ES256 also supported
JWT_PUBLIC_KEY_PATH=/secrets/jwt_public.pem  # PEM file for bearer token verification
# For symmetric HS256 (dev only — DO NOT use in production):
# JWT_SECRET_KEY=CHANGE_ME_dev_only

# ── MVNO / SM-DP+ ─────────────────────────────────────────────────────────────
SMDP_BASE_URL=https://smdp.telhone.akulearn.io   # SM-DP+ server for profile download orders
SMDP_API_KEY=CHANGE_ME                            # API key for the SM-DP+ platform
MVNO_OPERATOR_ID=akulearn-mvno                    # Operator identifier registered with the MVNO

# ── QR code service ───────────────────────────────────────────────────────────
QR_BASE_URL=https://qr.telhone.akulearn.io   # Base URL for QR code image generation

# ── OTA platform ──────────────────────────────────────────────────────────────
OTA_PLATFORM_URL=https://ota.telhone.akulearn.io  # MVNO OTA push platform endpoint
OTA_PLATFORM_API_KEY=CHANGE_ME                    # API key for the OTA platform
OTA_TIMEOUT_SECONDS=30                            # Max seconds to wait for OTA acknowledgment

# ── Aku-IGHub integration (device attestation) ────────────────────────────────
AKU_IGHUB_URL=https://ighub.akulearn.io      # Aku-IGHub service URL
AKU_IGHUB_API_KEY=CHANGE_ME                  # Service-to-service API key for IGHub calls
IGHUB_TIMEOUT_SECONDS=10                     # Timeout (seconds) for IGHub attestation calls

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.akulearn.io,https://admin.akulearn.io

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
